#!/usr/bin/env python3

import math
import threading
import time

import rclpy
from rclpy.node import Node

from geometry_msgs.msg import Twist
from nav_msgs.msg import Odometry
from geometry_msgs.msg import TransformStamped
import tf2_ros

from USART import control_speed, receive_data, send_upload_command, ser, set_motor_parameter


# -----------------------------
# Robot configuration
# -----------------------------

MOTOR_DIR = [1, -1, 1, -1]

TICKS_PER_REV = 1600
DIST_PER_REV_M = 0.208

METERS_PER_TICK = DIST_PER_REV_M / TICKS_PER_REV
TICKS_PER_METER = 1.0 / METERS_PER_TICK

TRACK_WIDTH_M = 0.14

CMD_SCALE = 800


# -----------------------------
# Robot pose
# -----------------------------

x_m = 0.0
y_m = 0.0
theta_rad = 0.0


def wrap_pi(a):
    while a >= math.pi:
        a -= 2 * math.pi
    while a < -math.pi:
        a += 2 * math.pi
    return a


# -----------------------------
# Encoder ticks
# -----------------------------

latest_ticks = [0, 0, 0, 0]
ticks_lock = threading.Lock()


def parse_mall(msg):

    msg = msg.strip()

    if not (msg.startswith("$MAll:") and msg.endswith("#")):
        return None

    payload = msg[len("$MAll:"):-1]
    parts = payload.split(",")

    if len(parts) != 4:
        return None

    t = [int(p) for p in parts]
    t = [t[i] * MOTOR_DIR[i] for i in range(4)]

    return t


def get_ticks():
    with ticks_lock:
        return latest_ticks[:]


# -----------------------------
# Serial RX thread
# -----------------------------

def rx_loop():

    while True:

        msg = receive_data()

        if msg:
            ticks = parse_mall(msg)

            if ticks is not None:
                with ticks_lock:
                    latest_ticks[:] = ticks

        time.sleep(0.001)


# -----------------------------
# Odometry integration
# -----------------------------

def integrate_pose(dL_ticks, dR_ticks):

    global x_m, y_m, theta_rad

    dL = dL_ticks * METERS_PER_TICK
    dR = dR_ticks * METERS_PER_TICK

    d = 0.5 * (dL + dR)
    dtheta = (dR - dL) / TRACK_WIDTH_M

    th_mid = theta_rad + 0.5 * dtheta

    x_m += d * math.sin(th_mid)
    y_m += d * math.cos(th_mid)

    theta_rad = wrap_pi(theta_rad + dtheta)


# -----------------------------
# Motor driver
# -----------------------------

def drive_raw(m1, m2, m3, m4):

    m = [m1, m2, m3, m4]
    m = [m[i] * MOTOR_DIR[i] for i in range(4)]

    control_speed(m[0], m[1], m[2], m[3])


def stop():
    drive_raw(0, 0, 0, 0)


# -----------------------------
# ROS Node
# -----------------------------

class WheelOdomNode(Node):

    def __init__(self):

        super().__init__("wheel_odometry")

        self.prev_ticks = get_ticks()

        self.cmd_sub = self.create_subscription(
            Twist,
            "/cmd_vel",
            self.cmd_vel_callback,
            10
        )

        self.odom_pub = self.create_publisher(
            Odometry,
            "/odom",
            10
        )

        self.tf_broadcaster = tf2_ros.TransformBroadcaster(self)

        self.timer = self.create_timer(
            0.02,
            self.update
        )

        self.get_logger().info("Wheel odometry node started")

    # -----------------------------
    # Velocity commands
    # -----------------------------

    def cmd_vel_callback(self, msg):

        v = msg.linear.x
        w = msg.angular.z

        self.get_logger().info(f"CMD_VEL: {v:.2f} {w:.2f}")

        left = v - (TRACK_WIDTH_M / 2.0) * w
        right = v + (TRACK_WIDTH_M / 2.0) * w

        left_cmd = int(left * CMD_SCALE)
        right_cmd = int(right * CMD_SCALE)

        drive_raw(left_cmd, right_cmd, right_cmd, left_cmd)

    # -----------------------------
    # Update loop
    # -----------------------------

    def update(self):

        global x_m, y_m, theta_rad

        now = get_ticks()

        dL = 0.5 * ((now[0] - self.prev_ticks[0]) + (now[3] - self.prev_ticks[3]))
        dR = 0.5 * ((now[1] - self.prev_ticks[1]) + (now[2] - self.prev_ticks[2]))

        integrate_pose(dL, dR)

        self.prev_ticks = now

        self.publish_odom()
        self.publish_tf()

    # -----------------------------
    # Publish odometry
    # -----------------------------

    def publish_odom(self):

        odom = Odometry()

        odom.header.stamp = self.get_clock().now().to_msg()
        odom.header.frame_id = "odom"
        odom.child_frame_id = "base_link"

        odom.pose.pose.position.x = x_m
        odom.pose.pose.position.y = y_m

        qz = math.sin(theta_rad / 2)
        qw = math.cos(theta_rad / 2)

        odom.pose.pose.orientation.z = qz
        odom.pose.pose.orientation.w = qw

        self.odom_pub.publish(odom)

    # -----------------------------
    # Publish TF
    # -----------------------------

    def publish_tf(self):

        t = TransformStamped()

        t.header.stamp = self.get_clock().now().to_msg()
        t.header.frame_id = "odom"
        t.child_frame_id = "base_link"

        t.transform.translation.x = x_m
        t.transform.translation.y = y_m

        qz = math.sin(theta_rad / 2)
        qw = math.cos(theta_rad / 2)

        t.transform.rotation.z = qz
        t.transform.rotation.w = qw

        self.tf_broadcaster.sendTransform(t)


# -----------------------------
# Main
# -----------------------------

def main():

    rclpy.init()

    send_upload_command(1)
    time.sleep(0.1)
    set_motor_parameter()

    threading.Thread(target=rx_loop, daemon=True).start()

    node = WheelOdomNode()

    rclpy.spin(node)

    stop()
    ser.close()

    rclpy.shutdown()


if __name__ == "__main__":
    main()
